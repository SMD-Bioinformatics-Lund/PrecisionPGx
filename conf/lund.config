/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for Lund params for the pipeline.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines reference genomes using Lund genome paths.
----------------------------------------------------------------------------------------
*/


params {

    // Reference Genome Information
    genome                          = 'GRCh38'
    igenomes_ignore                 = true
    igenomes_base                   = null
    local_genomes                   = '/fs1/resources/ref/'
    save_reference                  = false

    // Main Params    
    restrict_to_contigs             = null
    save_mapped_as_cram             = false
    skip_tools                      = null
    skip_subworkflows               = null
    platform                        = 'illumina'

    // Reference Genome Paths
    fasta                           = "${params.local_genomes}/hg38/fasta/masked/GCA_000001405.15_GRCh38_no_alt_analysis_set_nochr_masked.fna"
    fai                             = "${params.local_genomes}/hg38/fasta/masked/GCA_000001405.15_GRCh38_no_alt_analysis_set_nochr_masked.fna.fai"
    sequence_dictionary             = "${params.local_genomes}/hg38/fasta/masked/GCA_000001405.15_GRCh38_no_alt_analysis_set_nochr_masked.dict"
    bwa                             = "${params.local_genomes}/hg38/fasta/masked/"
    // bwamem2                         = "${params.local_genomes}/hg38/fasta/masked/GCA_000001405.15_GRCh38_no_alt_analysis_set_nochr_masked.{amb,ann,bwt,pac,sa}"
    bwamem2                         = "${params.local_genomes}/hg38/fasta/masked/"
    bwameme                         = null
    target_bed                      = "${params.local_genomes}/hg38/bed/pharmacogenomics/orebro/pgx_panelv2_TE-97619858_hg38_grch38_refseq_mane_whole_genes_and_snps_PAD50_VARIANT_CALLING_240412.sorted.bed"
    intervals_wgs                   = null

    // Alignment
    aligner                         = 'sentieon'
    mbuffer_mem                     = 10240 
    samtools_sort_threads           = 12
    min_trimmed_length              = 40
    rmdup                           = false

    // Variant calling
    variant_caller                  = 'sentieon' // gatk4, sentieon, deepvariant, bcbio
    ml_model                        = "https://s3.amazonaws.com/sentieon-release/other/SentieonDNAscopeModel1.1.model"
    emit_mode                       = 'confident' // "variant, confident, all, gvcf : applicable only for sentieon
    filter_vcf                      = true

    // CNV Calling
    // TODO: 

    // HLA Calling
    // TODO:

    // Phamrcat
    pharmcat_version                = '3.1.1' 
    pharmcat                        = true
    pharmcat_resource_dir           = "${baseDir}/assets/pharmcat_resources"
    pharmcat_reference_fasta        = "${params.local_genomes}/hg38/fasta/pharmcat/reference.fna.bgz"
    pharmcat_reference_fasta_index  = "${params.local_genomes}/hg38/fasta/pharmcat/reference.fna.bgz.csi"
    pharmcat_reference_fasta_fai    = "${params.local_genomes}/hg38/fasta/pharmcat/reference.fna.bgz.fai"
    pharmcat_positions_no_chr       = "${params.pharmcat_resource_dir}/pharmcat_positions_nochr_${params.pharmcat_version}.vcf.gz"
    pharmcat_positions              = "${params.pharmcat_resource_dir}/pharmcat_positions_${params.pharmcat_version}.vcf.gz"
    pharmcat_positions_index        = "${params.pharmcat_resource_dir}/pharmcat_positions_${params.pharmcat_version}.vcf.gz.tbi"
    pharmcat_uniallelic_pos         = "${params.pharmcat_resource_dir}/pharmcat_positions_${params.pharmcat_version}.uniallelic.vcf.gz"
    pharmcat_uniallelic_pos_index   = "${params.pharmcat_resource_dir}/pharmcat_positions_${params.pharmcat_version}.uniallelicvcf.gz.tbi"
    // TODO:

    // MultiQC
    // multiqc_config                  = 'assets/multiqc_config.yml'
    multiqc_title                   = 'PrecisionPGx Lund'
    // multiqc_logo                    = 'assets/PrecisionPGx-light.png'
    max_multiqc_email_size          = '25.MB'
    // multiqc_methods_description     = 'assets/methods_description_template.yml'

    // Biolerplate params
    email                           = 'ram.nanduri@skane.se'
    email_on_fail                   = 'ram.nanduri@skane.se'

    // config options
    config_profile_name             = 'lund'
    config_profile_description      = 'Lund config'

}

process {
  executor                        = "slurm"
  queue                           = "high"
  time                            = 48.h
}

executor {
    name                          = 'slurm'
    queueSize                     = 10
    pollInterval                  = '5 sec'
}

// singularity {
//     cacheDir                      = "${baseDir}/.singularity"
// }

env{
  SENTIEON_LICENSE                    = '10.139.0.101:8990'
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    SMD-Bioinformatics-Lund/PrecisionPGx Nextflow Lund base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    A 'blank slate' config file, appropriate for general use on most high performance
    compute environments. Assumes that all software is installed and available on
    the PATH. Runs in `local` mode - all jobs will be run on the logged in environment.
----------------------------------------------------------------------------------------
*/

process {

    // Defaults for all processes
    cpus   = { 2      * task.attempt }
    memory = { 6.GB   * task.attempt }
    time   = { 4.h    * task.attempt }

    errorStrategy = { task.exitStatus in ((130..145) + 104 + 175) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // Process-specific resource requirements
    // NOTE - Please try and reuse the labels below as much as possible.
    //        These labels are used and recognised by default in DSL2 files hosted on nf-core/modules.
    //        If possible, it would be nice to keep the same label naming convention when
    //        adding in your local modules too.
    // See https://www.nextflow.io/docs/latest/config.html#config-process-selectors
    withLabel:process_single {
        cpus   = { 1                   }
        memory = { 6.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 6     * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 20     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel:process_high {
        cpus   = { 40    * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }
    withLabel:process_long {
        time   = { 20.h  * task.attempt }
    }
    withLabel:process_medium_memory {
        memory = { 50.GB * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 200.GB * task.attempt }
    }
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
    withLabel: process_gpu {
        ext.use_gpu = { workflow.profile.contains('gpu') }
        accelerator = { workflow.profile.contains('gpu') ? 1 : null }
    }
}