/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args            = Additional arguments appended to command in module.
        ext.args2           = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3           = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix          = File name prefix for output files.
        ext.when            = Conditional clause
----------------------------------------------------------------------------------------
*/

//
// pharmcat genotyping reporting options
// ext.args = {" --matcher-save-html --matcher-all-results --genes ${params.pharmcat_selected_genes}"}


process {
    withName: '.*PHARMCAT_GENOTYPING_REPORTING_SELECTED:.*' {
        ext.when    = { meta.genes }
        publishDir = [
            path: { "${params.outdir}/pharmcat/selected_genes" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        ]
    }

    withName: '.*PHARMCAT_GENOTYPING_REPORTING_SELECTED:PHARMCAT_MATCHER' {
        ext.when    = { meta.genes }
        ext.args = {" --matcher-save-html --matcher-all-results"}
        ext.prefix = { "${meta.id}.${params.variant_caller}.pharmcat.selected_genes" }
    }

    withName: '.*PHARMCAT_GENOTYPING_REPORTING_SELECTED:PHARMCAT_PHENOTYPER' {
        ext.when    = { meta.genes }
        ext.prefix = { "${meta.id}.${params.variant_caller}.pharmcat.selected_genes" }
    }
    
    withName: '.*PHARMCAT_GENOTYPING_REPORTING_SELECTED:PHARMCAT_REPORTER' {
        ext.when    = { meta.genes }
        ext.args = {" --reporter-sources ${params.pharmcat_reporter_sources} --reporter-save-html --reporter-save-json --reporter-save-calls-only-tsv --reporter-title ${meta.id} "}
        ext.prefix = { "${meta.id}.${params.variant_caller}.pharmcat.selected_genes" }
    }
}
